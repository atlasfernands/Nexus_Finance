# GEMINI_API_KEY: Server-only key used by the Vercel API route for Nexus AI.
# Never expose this as VITE_GEMINI_API_KEY because VITE variables go to the browser.
GEMINI_API_KEY="SUA_API_KEY_AQUI"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Auth
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Optional public base URL for API calls from Android/Capacitor builds.
# Leave empty on Vercel web deploys so the app uses same-origin /api routes.
VITE_API_BASE_URL=""
