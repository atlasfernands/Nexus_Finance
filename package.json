{
  "name": "nexus-finance",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "mobile:build": "npm run build",
    "mobile:sync": "npm run mobile:build && node scripts/prepare-capacitor-assets.mjs && node scripts/run-mobile-command.mjs cap sync android",
    "android:open": "npm run mobile:sync && node scripts/run-mobile-command.mjs cap open android",
    "android:run": "npm run mobile:sync && node scripts/run-mobile-command.mjs cap run android",
    "android:apk:debug": "npm run mobile:sync && node scripts/run-gradle.mjs assembleDebug",
    "android:aab:release": "npm run mobile:sync && node scripts/run-gradle.mjs bundleRelease",
    "android:devices": "node scripts/run-mobile-command.mjs adb devices -l",
    "android:accel-check": "node scripts/run-mobile-command.mjs emulator -accel-check",
    "android:emulator": "node scripts/run-mobile-command.mjs emulator -avd NexusFinance_API36",
    "android:install:debug": "node scripts/run-mobile-command.mjs adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:launch": "node scripts/run-mobile-command.mjs adb shell monkey -p com.nexusfinance.app 1"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@google/genai": "^1.50.1",
    "@supabase/supabase-js": "^2.104.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.5"
  }
}
